{
  "name": "jeldon",
  "version": "0.0.0",
  "private": true,
  "description": "Jeldon Core — a portable article + AEO/SEO + analytics engine. The engine is the invariant; a Domain Pack is the only thing a new project edits.",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "gen:schema": "node scripts/gen-schema.mjs",
    "changeset": "changeset",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/node": "^22.7.5",
    "tsup": "^8.3.0",
    "turbo": "^2.2.3",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4",
    "zod-to-json-schema": "^3.23.5"
  }
}
