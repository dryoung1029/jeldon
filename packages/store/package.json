{
  "name": "@jeldon/store",
  "version": "0.1.0",
  "description": "Domain-agnostic content persistence. interface Store + GitHubStore (Contents/Trees API with SHA-conflict re-fetch + out-of-band frontmatter merge) + FsStore fallback for tests and non-GitHub hosts.",
  "type": "module",
  "license": "UNLICENSED",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@jeldon/config": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
