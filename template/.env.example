# Copy to .env (local) and set as Cloudflare + GitHub Actions secrets.
# The authoritative list is `services.requiredEnv` in jeldon.config.ts; the
# starter lists the two below. `jeldon doctor` verifies each one is present.

# Store adapter (GitHub-as-database). Fine-grained PAT, Contents: read/write.
GITHUB_TOKEN=

# LLM key for the drafting capability.
ANTHROPIC_API_KEY=

# Add a line here for every additional entry you put in services.requiredEnv,
# e.g. PERPLEXITY_API_KEY, SERPAPI_KEY, CF_ANALYTICS_TOKEN, CITE8_API_KEY.
